# 依存ライブラリ（Node.js等を使う場合）
node_modules/
dist/
build/

# OSが自動生成する隠しファイル（Mac / Windows）
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# エディタ・IDEの設定
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/

# ログファイル
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 環境変数・ローカル設定（機密情報を含む可能性があるファイル）
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
